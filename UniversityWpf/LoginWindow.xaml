<Window x:Class="UniversityWpf.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему"
        Width="420" Height="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#2C3E50" Offset="0"/>
            <GradientStop Color="#34495E" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <Grid>
        <Border Background="White" CornerRadius="8" Margin="30"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Opacity="0.3" ShadowDepth="0"/>
            </Border.Effect>

            <StackPanel Margin="36" VerticalAlignment="Center">

                <TextBlock Text="Университет" FontSize="22" FontWeight="Bold"
                           Foreground="#2C3E50" HorizontalAlignment="Center"
                           Margin="0,0,0,4"/>
                <TextBlock Text="Панель администратора" FontSize="12"
                           Foreground="#999999" HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>

                <TextBlock Text="Логин" FontSize="12" Foreground="#666666"
                           Margin="0,0,0,6"/>
                <TextBox x:Name="LoginBox" Height="38" Margin="0,0,0,16"
                         FontSize="14" Padding="10,8"/>

                <TextBlock Text="Пароль" FontSize="12" Foreground="#666666"
                           Margin="0,0,0,6"/>
                <PasswordBox x:Name="PasswordBox" Height="38" Margin="0,0,0,10"
                             FontSize="14" Padding="10,8"/>

                <TextBlock x:Name="ErrorText" Foreground="#E74C3C"
                           FontSize="12" Margin="0,0,0,14" Visibility="Collapsed"/>

                <Button Content="Войти" Height="42" Background="#2980B9"
                        Foreground="White" BorderThickness="0"
                        FontWeight="SemiBold" FontSize="15"
                        Click="LoginClick">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="5" Padding="10">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2471A3"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </StackPanel>
        </Border>
    </Grid>
</Window>
